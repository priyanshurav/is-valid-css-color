{
  "name": "is-valid-css-color",
  "version": "3.1.0",
  "description": "A fast, lightweight validator for modern CSS color strings.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist/"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "test": "node --import tsx --test",
    "test:watch": "node --import tsx --test --watch",
    "test:coverage": "c8 node --import tsx --test",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ."
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/priyanshurav/is-valid-css-color.git"
  },
  "keywords": [
    "css",
    "color",
    "colour",
    "validate",
    "validator",
    "validation",
    "checker",
    "hex",
    "rgb",
    "hsl",
    "hwb",
    "lab",
    "lch",
    "oklab",
    "oklch",
    "named-color",
    "color-keywords",
    "color-space",
    "display-p3",
    "srgb",
    "rec2020",
    "css-color-4",
    "typescript"
  ],
  "author": {
    "name": "Priyanshu Rav",
    "url": "https://github.com/priyanshurav"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/priyanshurav/is-valid-css-color/issues"
  },
  "homepage": "https://github.com/priyanshurav/is-valid-css-color#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.0",
    "c8": "^11.0.0",
    "eslint": "^10.5.0",
    "eslint-plugin-regexp": "^3.1.0",
    "globals": "^17.7.0",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.9.0",
      "onFail": "download"
    }
  }
}
