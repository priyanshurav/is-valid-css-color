{
  "name": "is-valid-css-color",
  "version": "3.0.0",
  "description": "A fast, lightweight validator for modern CSS color strings.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "files": [
    "dist/"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "test": "node --import tsx --test",
    "test:coverage": "c8 node --import tsx --test",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ."
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/priyanshurav/is-valid-css-color.git"
  },
  "keywords": [
    "css",
    "color",
    "colour",
    "validate",
    "validator",
    "check",
    "hex",
    "rgb",
    "hsl",
    "oklch",
    "oklab",
    "lch",
    "lab",
    "hwb",
    "named-color",
    "css-color-4",
    "color-format",
    "typescript"
  ],
  "author": {
    "name": "Priyanshu Rav",
    "url": "https://github.com/priyanshurav"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/priyanshurav/is-valid-css-color/issues"
  },
  "homepage": "https://github.com/priyanshurav/is-valid-css-color#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.2",
    "c8": "^11.0.0",
    "eslint": "^10.4.1",
    "eslint-plugin-regexp": "^3.1.0",
    "globals": "^17.6.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.5.0",
      "onFail": "download"
    }
  }
}
